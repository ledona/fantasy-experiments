// dict mapping "{sport}-{contest-style}" to a list of gen lineup params to be tried in
// succession to generate a "rational" lineup using typical stategic lineup generation constraints
{
    "mlb-classic": [
        {
            // should work for most slates
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 70,
            "stackable_players_ppg_pctl": 55,
            "exclude_below_ppg_pctl": {"P": 70, "": 45},
            "exclude_below_games_played": 4,
            "constraints": [
                ["no_opp_team", {"position": "P", "opp_excluded_positions": ["C","1B","2B","3B","SS","LF","CF","RF","OF","DH"]}]
            ]
        },
        {
            // for small slates (5-3 games)
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 60,
            "stackable_players_ppg_pctl": 45,
            "exclude_below_ppg_pctl": {"P": 50, "": 30},
            "exclude_below_games_played": 2,
            "constraints": [
                ["no_opp_team", {"position": "P", "opp_excluded_positions": ["C","1B","2B","3B","SS","LF","CF","RF","OF","DH"]}]
            ]
        },
        {
            // for mini slate (2 games or very early season)
            "stacks": [4, 2],
            "stackable_teams_predicted_pctl": 50,
            "stackable_players_ppg_pctl": 25,
            "exclude_below_ppg_pctl": {"P": 25, "": 20},
            "exclude_below_games_played": 1,
            "constraints": [
                ["no_opp_team", {
                    "position": "P", 
                    "opp_excluded_positions": ["C","1B","2B","3B","SS","LF","CF","RF","OF","DH"],
                    "max_opp_players": 1
                }]
            ]
        },
        {
            "stacks": [4],
            "stackable_teams_predicted_pctl": 50,
            "stackable_players_ppg_pctl": 25,
            "exclude_below_ppg_pctl": {"P": 25, "": 20},
            "exclude_below_games_played": 1,
            "constraints": [
                ["no_opp_team", {
                    "position": "P", 
                    "opp_excluded_positions": ["C","1B","2B","3B","SS","LF","CF","RF","OF","DH"],
                    "max_opp_players": 1
                }]
            ]
        }
    ],
    "mlb-showdown": [
        {
            // Pitcher/Hitter Split: If a starting pitcher CPT, max of 2 opposing hitters
            "exclude_for_cost": ["<=", "3000"],
            "slot_pos_opp_team_cap": "CPT:P:1.DH,C,1B,2B,3B,SS,LF,CF,RF,OF,DH"
        }
    ],
    "nba-classic": [
        {
            "stacks": [3, 3],
            "stackable_teams_predicted_pctl": 60,
            "stackable_players_ppg_pctl": 40,
            "exclude_below_ppg_pctl": {"": 35},
            "exclude_below_games_played": 2,
            "exclude_for_cost": ["<", 3000]
        },
        {
            // ~4 game slate
            "stacks": [3, 3],
            "stackable_teams_predicted_pctl": 55,
            "exclude_below_ppg_pctl": {"": 20},
            "exclude_below_games_played": 2
        },
        {
            "stacks": [3],
            "stackable_teams_predicted_pctl": 50,
            "exclude_below_games_played": 1
        },
        {
            "stacks": [3],
            "stackable_teams_predicted_pctl": 35,
            "exclude_below_games_played": 1
        }
    ],
    "nba-showdown": [
        {
            // Star Allocation: Force the lineup to contain at least 2 of the top 80th ppg percentile players
            "ppg_pctl_player_pool": [2, 70],
            "exclude_for_cost": ["<", "2000"]
        },
        {
            "ppg_pctl_player_pool": [2, 60],
            "exclude_for_cost": ["<", "2000"]
        },
        {
            "ppg_pctl_player_pool": [2, 40],
            "exclude_for_cost": ["<", "2000"]
        }
    ],
    "nfl-classic": [
        {
            // should work for most slates
            "stacks": [2, 2],
            "stackable_teams_predicted_pctl": 90,
            "stackable_players_ppg_pctl": 65,
            "exclude_below_ppg_pctl": {"QB": 80},
            "exclude_for_cost": ["<=", 2500],
            "constraints": [
                ["stack_same_team_diff_pos", {
                    "position": "QB",
                    "team_position": "team.D",
                    "stack_positions": ["TE", "WR"]
                }],
                ["no_opp_team", {"team_position": "team.D", "position": "team.D"}],
                ["max_team_players", {"max_players": 2, "positions": ["TE", "WR"]}],
                ["max_team_players", {"max_players": 1, "positions": ["RB"]}]
            ]
        },
        {
            "stacks": [2, 2],
            "stackable_teams_predicted_pctl": 75,
            "stackable_players_ppg_pctl": 65,
            "exclude_below_ppg_pctl": {"QB": 80},
            "exclude_for_cost": ["<=", 2500],
            "constraints": [
                ["stack_same_team_diff_pos", {
                    "position": "QB",
                    "team_position": "team.D",
                    "stack_positions": ["TE", "WR"]
                }],
                ["no_opp_team", {"team_position": "team.D", "position": "team.D"}],
                ["max_team_players", {"max_players": 2, "positions": ["TE", "WR"]}],
                ["max_team_players", {"max_players": 1, "positions": ["RB"]}]
            ]
        }
    ],
    "nfl-showdown": [
        {
            // TODO: Captain/MVP Match: If a Quarterback (QB) is your Captain/MVP, force at least 1 Wide Receiver (WR) or Tight End (TE) from the same team into a flex spot.
            // Anti-Correlation Rule: Do not allow a Defense (DST) and the opposing starting Quarterback or
            //      TODO: opposing top rb or WR in the same lineup.
            "exclude_for_cost": ["<", "2000"],
            "constraints": [
                ["no_opp_team", {
                    "team_position": "team.D", 
                    "position": "team.D", 
                    "opp_excluded_positions": ["QB"]
                }]
            ]
        }
    ],
    "nhl-classic": [
        {
            // should work for most slates
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 80,
            "stackable_players_ppg_pctl": 65,
            "exclude_below_ppg_pctl": {"G": 80},
            "exclude_for_cost": ["<", 4000],
            "constraints": [
                ["no_opp_team", {"position": "G", "opp_excluded_positions": ["W","LW","RW","C"]}]
            ]
        },
        {
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 60,
            "stackable_players_ppg_pctl": 55,
            "exclude_below_ppg_pctl": {"G": 60},
            "exclude_for_cost": ["<", 4000],
            "constraints": [
                ["no_opp_team", {"position": "G", "opp_excluded_positions": ["W","LW","RW","C"]}]
            ]
        },
        {
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 60,
            "stackable_players_ppg_pctl": 55,
            "exclude_below_ppg_pctl": {"G": 60},
            "exclude_for_cost": ["<", 3500],
            "constraints": [
                ["no_opp_team", {"position": "G", "opp_excluded_positions": ["W","LW","RW","C"]}]
            ]
        },
        {
            // fallback for failure to solve but with a large number of games, so lossen exclusion but increase stackable threshold
            "stacks": [4, 3],
            "stackable_teams_predicted_pctl": 75,
            "stackable_players_ppg_pctl": 55,
            "exclude_below_ppg_pctl": {"G": 60},
            "exclude_for_cost": ["<", 3000],
            "constraints": [
                ["no_opp_team", {"position": "G", "opp_excluded_positions": ["W","LW","RW","C"]}]
            ]
        }
    ],
    "nhl-showdown": [
        {
            // TODO:  Line Correlation: Force at least one 2+ line combination (skaters from the same team and same line number).
            // Goalie/Skater Lock: If the Goalie is your Captain/MVP, max of 2 opposing skaters (Centers/Wingers).
            "exclude_for_cost": ["<=", "2000"],
            "slot_pos_opp_team_cap": "CPT:G:2.W,LW,RW,C"
        }
    ]
}