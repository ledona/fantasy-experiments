{
    "sport": "nba",
    "global_default": {
        "seed": 1,
        "validation_season": 20222023,
        "recent_games": 5,
        "training_seasons": [
            20082009,
            20092010,
            20102011,
            // 20112012,  Lockout season
            20122013,
            20132014,
            20142015,
            20152016,
            20162017,
            20172018,
            20182019,
            // 20192020,  Covid bubble season
            20202021,
            20212022,
            // 20222023, validation
            20232024,
            20242025
        ],
        "missing_data_threshold": 0.09,
        "train_params": {
            "nn.early_stop": 20,
            "early_stop": 3,
            "tp:population_size": 50,
            "max_time_mins": 360
        }
    },
    "model_groups": [
        {
            "data_filename": "nba_team.parquet",
            "p_or_t": "T",
            "train_params": {
                "n_jobs": 8,
                "nn:learning_rate": 0.00001,
                "nn:hidden_layers": 1,
                "epochs_max": 1000
            },
            "models": {
                "NBA-team-pts": {
                    "target": [
                        "stat",
                        "pts"
                    ]
                },
                "NBA-team-win": {
                    "target": [
                        "stat",
                        "win"
                    ]
                }
            }
        },
        {
            "data_filename": "nba_player.parquet",
            "p_or_t": "P",
            "include_pos": true,
            "pos_remap": {"C": "C", "G": "PG,G,SG", "F": "F,SF,PF"},
            "train_params": {
                "n_jobs": 4,
                "tp:population_size": 40,
                "tp:max_eval_time_mins": 15,
                "nn.epochs_max": 500,
                "nn:learning_rate": 0.000001,
                "nn:hidden_layers": 3
            },
            "models": {
                "NBA-DK": {
                    // "cols_to_drop": [
                    //     "calc:(y|fd)_score.+"
                    // ],
                    "target": [
                        "calc",
                        "dk_score"
                    ]
                },
                "NBA-player-pts": {
                    "target": [
                        "stat",
                        "pts"
                    ],
                    "cols_to_drop": [
                        "calc:.+score.+"
                    ]
                },
                "NBA-player-asst": {
                    "target": [
                        "stat",
                        "asst"
                    ],
                    "cols_to_drop": [
                        "calc:.+score.+"
                    ]
                },
                "NBA-player-fgatt": {
                    "target": [
                        "stat",
                        "fg_att"
                    ],
                    "cols_to_drop": [
                        "calc:.+score.+"
                    ]
                },
                "NBA-player-oreb": {
                    "target": [
                        "stat",
                        "o_reb"
                    ],
                    "cols_to_drop": [
                        "calc:.+score.+"
                    ]
                },
                "NBA-player-dreb": {
                    "target": [
                        "stat",
                        "d_reb"
                    ],
                    "cols_to_drop": [
                        "calc:.+score.+"
                    ]
                }
            }
        }
    ]
}